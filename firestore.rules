rules_version = '2';

// Firestore security rules for ALU Venture Connect.
//
// A few rules below call get() on another document (isFounder,
// isVerifiedStartup, isAdmin) to check ownership/role. Each get() is a
// billed Firestore read charged against the request, on top of whatever
// documents the query itself returns — acceptable at this app's current
// scale, but worth knowing if opportunity/application volume grows a lot
// (the fix then is denormalizing verificationStatus onto the opportunity
// at write time instead of re-checking it live).
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isFounder(startupId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/startups/$(startupId)).data.ownerUid == request.auth.uid;
    }

    function isVerifiedStartup(startupId) {
      return get(/databases/$(database)/documents/startups/$(startupId)).data.verificationStatus == 'verified';
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // users/{uid} — one profile document per account, keyed by auth uid.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(uid);
      allow delete: if false;
    }

    // opportunities/{opportunityId} — readable by any signed-in user;
    // creatable only by the founder of a startup that has actually been
    // verified (the real enforcement of "only approved startups may post" —
    // hiding the button in the UI is a courtesy, this is the boundary).
    match /opportunities/{opportunityId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.postedByUid &&
        isFounder(request.resource.data.startupId) &&
        isVerifiedStartup(request.resource.data.startupId);
      allow update, delete: if isSignedIn() &&
        request.auth.uid == resource.data.postedByUid;
    }

    // applications/{applicationId} — a student can create/read their own
    // applications; the founder who owns the startup being applied to can
    // also read them and update only the status (not rewrite the applicant's
    // data).
    match /applications/{applicationId} {
      allow read: if isSignedIn() &&
        (request.auth.uid == resource.data.studentId || isFounder(resource.data.startupId));
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.studentId;
      allow update: if isSignedIn() && isFounder(resource.data.startupId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']);
      allow delete: if false;
    }

    // startups/{startupId} — a founder creates and edits their own startup,
    // but cannot touch their own verificationStatus; only an admin can flip
    // that field, and only that field.
    match /startups/{startupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.ownerUid &&
        request.resource.data.verificationStatus == 'pending';
      allow update: if isSignedIn() && (
        (request.auth.uid == resource.data.ownerUid &&
          request.resource.data.verificationStatus == resource.data.verificationStatus) ||
        (isAdmin() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['verificationStatus']))
      );
      allow delete: if false;
    }
  }
}
