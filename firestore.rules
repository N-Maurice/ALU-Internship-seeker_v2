rules_version = '2';

// Firestore security rules for ALU Venture Connect.
//
// Startup verification is no longer required to post opportunities — any
// founder can post for their own startup, regardless of `verificationStatus`
// (kept as a field/admin screen for possible future use, just not enforced
// as a gate here). isFounder() still does a get() to confirm ownership,
// which is a billed Firestore read on top of whatever the query returns —
// acceptable at this app's scale.
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isFounder(startupId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/startups/$(startupId)).data.ownerUid == request.auth.uid;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // users/{uid} — one profile document per account, keyed by auth uid.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(uid);
      allow delete: if false;
    }

    // opportunities/{opportunityId} — readable by any signed-in user;
    // creatable by any founder for their own startup (no verification gate).
    match /opportunities/{opportunityId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.postedByUid &&
        isFounder(request.resource.data.startupId);
      allow update, delete: if isSignedIn() &&
        request.auth.uid == resource.data.postedByUid;
    }

    // applications/{applicationId} — a student can create/read their own
    // applications; the founder who owns the startup being applied to can
    // also read them and update only the status (not rewrite the applicant's
    // data).
    match /applications/{applicationId} {
      allow read: if isSignedIn() &&
        (request.auth.uid == resource.data.studentId || isFounder(resource.data.startupId));
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.studentId;
      allow update: if isSignedIn() && isFounder(resource.data.startupId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']);
      allow delete: if false;
    }

    // startups/{startupId} — a founder creates and edits their own startup.
    // verificationStatus is still admin-only to change post-creation (kept
    // for a possible future re-introduction of a review flow), but it's no
    // longer required to be 'pending' at creation, and no longer gates
    // anything on the opportunities rule above.
    match /startups/{startupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.ownerUid;
      allow update: if isSignedIn() && (
        (request.auth.uid == resource.data.ownerUid &&
          request.resource.data.verificationStatus == resource.data.verificationStatus) ||
        (isAdmin() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['verificationStatus']))
      );
      allow delete: if false;
    }

    // conversations/{conversationId} — one thread per (student, startup)
    // pair, doc id is the deterministic `'${studentId}_$startupId'`. Only
    // the two participants (the student, or the founder who owns the
    // startup) can read or write it. A participant can update summary
    // fields (last message, unread counts) but not reassign who the
    // conversation is between.
    match /conversations/{conversationId} {
      allow read: if isSignedIn() &&
        (request.auth.uid == resource.data.studentId || isFounder(resource.data.startupId));
      allow create: if isSignedIn() &&
        conversationId == request.resource.data.studentId + '_' + request.resource.data.startupId &&
        (request.auth.uid == request.resource.data.studentId ||
          isFounder(request.resource.data.startupId));
      allow update: if isSignedIn() &&
        (request.auth.uid == resource.data.studentId || isFounder(resource.data.startupId)) &&
        request.resource.data.studentId == resource.data.studentId &&
        request.resource.data.startupId == resource.data.startupId;
      allow delete: if false;
    }

    // messages/{messageId} — each message denormalizes studentId/startupId
    // directly (see MessageModel) so this rule is self-contained, no get()
    // through the conversation doc needed.
    match /messages/{messageId} {
      allow read: if isSignedIn() &&
        (request.auth.uid == resource.data.studentId || isFounder(resource.data.startupId));
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.senderId &&
        (request.auth.uid == request.resource.data.studentId ||
          isFounder(request.resource.data.startupId));
      allow update, delete: if false;
    }
  }
}
